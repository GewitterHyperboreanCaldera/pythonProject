        "    targets=int_sequence[3:],\n",
        "    sequence_length=3,\n",
        "    batch_size=2\n",
        ")\n",
        "\n",
        "for inputs, targets in dummy_dataset:\n",
        "    for i in range(inputs.shape[0]):\n",

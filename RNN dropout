    {
      "cell_type": "code",
      "source": [
        "num_train_samples = int(0.5 * len(raw_data))\n",
        "num_val_samples = int(0.25 * len(raw_data))\n",
        "num_test_samples = len(raw_data) - num_train_samples - num_val_samples\n",
        "train_data = raw_data[:num_train_samples]\n",
        "train_targets = temperature[:num_train_samples]\n",
        "val_data = raw_data[num_train_samples : num_train_samples + num_val_samples]\n",
        "val_targets = temperature[num_train_samples : num_train_samples + num_val_samples]\n",
        "test_data = raw_data[num_train_samples + num_val_samples :]\n",
        "test_targets = temperature[num_train_samples + num_val_samples :]\n",
        "print(\"Training samples:\", len(train_data))\n",
        "print(\"Validation samples:\", len(val_data))\n",
        "print(\"Testing samples:\", len(test_data))"
